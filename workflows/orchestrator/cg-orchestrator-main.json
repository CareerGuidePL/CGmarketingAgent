    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst response = (item.data?.text || item.output || item.text || item.content || item.response || JSON.stringify(item)).toString().trim().toLowerCase();\n\nlet decision;\nif (response === 'ok' || response === 'tak' || response === 'yes') {\n  decision = 'approve';\n} else if (response === 'nie' || response === 'no' || response === 'odrzuc' || response === 'odrzuć') {\n  decision = 'reject';\n} else {\n  decision = 'revise';\n}\n\nconst rowId = $('Search Row ID').first().json._id;\nconst jobId = $('Get Jobs To Process').first().json.job_id;\nconst feedback = item.data?.text || item.output || item.text || item.content || item.response || '';\n\nreturn [{ json: { decision, feedback, job_id: jobId, row_id: rowId } }];"
      },
