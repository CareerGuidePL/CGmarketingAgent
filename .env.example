# Skopiuj do pliku `.env` i uzupełnij wartości.
# Uwaga: Cursor nie ładuje automatycznie `.env` do `.cursor/mcp.json` —
# po uzupełnieniu skopiuj N8N_* do sekcji `env` serwera `n8n-mcp` w `.cursor/mcp.json`
# albo ustaw te same zmienne w środowisku systemu przed uruchomieniem Cursor.

# --- Docker Compose / n8n — VPS (główna instancja zespołu) lub lokalny dev ---
# Wygeneruj stały klucz (nie zmieniaj po utworzeniu bazy z credentialami):
#   openssl rand -base64 32
N8N_ENCRYPTION_KEY=

# Host i URL webhooków:
#  VPS (prod zespołu) — przykład:
# N8N_HOST=cg-agent.n8n.crait.pro
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://cg-agent.n8n.crait.pro/
#  Lokalnie (dev):
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5679/

# Opcjonalnie: ngrok w Dockerze (docker compose --profile tunnel up -d)
# Token: https://dashboard.ngrok.com/get-started/your-authtoken
#
# --- Ten sam publiczny URL u całego zespołu (OAuth Google, webhooki) ---
# 1) W ngrok zarezerwuj domenę *.ngrok-free.dev (jedno konto).
# 2) WSZYSCY ustawiają TEN SAM token i TEN SAM publiczny adres (bezpiecznie, poza gitem):
# NGROK_AUTHTOKEN=
# NGROK_PUBLIC_URL=https://twoja-subdomena.ngrok-free.dev
# 3) N8N_HOST=twoja-subdomena.ngrok-free.dev  N8N_PROTOCOL=https  WEBHOOK_URL=https://twoja-subdomena.ngrok-free.dev/
# Bez NGROK_PUBLIC_URL agent dostaje losowy URL — stary link → ERR_NGROK_8012 / 502.
# Panel tunelu: http://127.0.0.1:4041

# Strefa czasowa workflowów (np. Cron)
GENERIC_TIMEZONE=Europe/Warsaw

# --- Discord Bot ---
# Token bota: Discord Developer Portal → aplikacja CG Agent → Bot → Reset Token
DISCORD_BOT_TOKEN=

# ID serwera: prawym na serwer → Copy Server ID (wymaga Developer Mode w Discordzie)
DISCORD_SERVER_ID=

# ID kanału cg-agent: prawym na kanał → Copy Channel ID
DISCORD_CHANNEL_ID=

# --- Seatable ---
# Base API Token (nie Account Token!): Seatable → otwórz bazę → ... → API Token → Generate (read-write)
SEATABLE_API_TOKEN=

# URL serwera Seatable (chmura lub self-hosted)
SEATABLE_SERVER_URL=https://cloud.seatable.io

# Nazwa bazy
SEATABLE_BASE_NAME=CG Marketing Agent

# --- MCP / narzędzia (opcjonalnie; nie muszą być ustawione dla samego kontenera n8n) ---
# Bazowy URL instancji n8n (bez końcowego slasha): instancja VPS zespołu albo localhost (dev).
# N8N_API_URL=https://cg-agent.n8n.crait.pro
N8N_API_URL=http://127.0.0.1:5679

# Klucz API: n8n → Settings → API
N8N_API_KEY=
